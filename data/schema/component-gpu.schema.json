{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "component-gpu.schema.json",
  "title": "GPU Component",
  "description": "Schema for GPU component YAML data files",
  "type": "object",
  "required": [
    "id",
    "type",
    "chip_manufacturer",
    "manufacturer",
    "model",
    "interface",
    "physical",
    "power",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier matching the filename stem"
    },
    "type": {
      "type": "string",
      "const": "gpu"
    },
    "chip_manufacturer": {
      "type": "string",
      "description": "GPU silicon designer (e.g. NVIDIA, AMD, Intel)"
    },
    "manufacturer": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "interface": {
      "type": "object",
      "required": ["pcie_gen", "lanes"],
      "additionalProperties": false,
      "properties": {
        "pcie_gen": {
          "type": "integer"
        },
        "lanes": {
          "type": "integer",
          "enum": [1, 4, 8, 16]
        }
      }
    },
    "physical": {
      "type": "object",
      "required": ["slot_width", "length_mm", "slots_occupied"],
      "additionalProperties": false,
      "properties": {
        "slot_width": {
          "type": "integer"
        },
        "length_mm": {
          "type": "number"
        },
        "slots_occupied": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4,
          "description": "Number of physical PCIe slot positions this card blocks"
        }
      }
    },
    "power": {
      "type": "object",
      "required": ["tdp_w", "recommended_psu_w", "power_connectors"],
      "additionalProperties": false,
      "properties": {
        "tdp_w": {
          "type": "number"
        },
        "recommended_psu_w": {
          "type": "number"
        },
        "power_connectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "count"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["6-pin", "8-pin", "12-pin", "16-pin/12VHPWR", "16-pin/12V-2x6"]
              },
              "count": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "description": "Power connector configuration for the GPU"
        }
      }
    },
    "schema_version": {
      "type": "string"
    }
  }
}
