{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "component-gpu.schema.json",
  "title": "GPU Component",
  "description": "Schema for GPU component YAML data files",
  "type": "object",
  "required": [
    "id",
    "type",
    "manufacturer",
    "model",
    "interface",
    "physical",
    "power",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier matching the filename stem"
    },
    "type": {
      "type": "string",
      "const": "gpu"
    },
    "manufacturer": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "interface": {
      "type": "object",
      "required": ["pcie_gen", "lanes"],
      "additionalProperties": false,
      "properties": {
        "pcie_gen": {
          "type": "integer"
        },
        "lanes": {
          "type": "integer"
        }
      }
    },
    "physical": {
      "type": "object",
      "required": ["slot_width", "length_mm"],
      "additionalProperties": false,
      "properties": {
        "slot_width": {
          "type": "integer"
        },
        "length_mm": {
          "type": "number"
        }
      }
    },
    "power": {
      "type": "object",
      "required": ["tdp_w", "recommended_psu_w"],
      "additionalProperties": false,
      "properties": {
        "tdp_w": {
          "type": "number"
        },
        "recommended_psu_w": {
          "type": "number"
        }
      }
    },
    "schema_version": {
      "type": "string"
    }
  }
}
