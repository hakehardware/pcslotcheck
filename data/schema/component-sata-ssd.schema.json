{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "component-sata-ssd.schema.json",
  "title": "SATA SSD Component",
  "description": "Schema for SATA SSD component YAML data files",
  "type": "object",
  "required": [
    "id",
    "type",
    "manufacturer",
    "model",
    "form_factor",
    "capacity_gb",
    "interface",
    "drive_type",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier matching the filename stem"
    },
    "type": {
      "type": "string",
      "const": "sata_ssd"
    },
    "manufacturer": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "form_factor": {
      "type": "string"
    },
    "capacity_gb": {
      "type": "number"
    },
    "interface": {
      "type": "string"
    },
    "drive_type": {
      "type": "string",
      "const": "ssd"
    },
    "schema_version": {
      "type": "string"
    }
  }
}
