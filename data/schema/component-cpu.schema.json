{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "component-cpu.schema.json",
  "title": "CPU Component",
  "description": "Schema for CPU component YAML data files",
  "type": "object",
  "required": [
    "id",
    "type",
    "manufacturer",
    "model",
    "socket",
    "microarchitecture",
    "architecture",
    "pcie_config",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier matching the filename stem"
    },
    "type": {
      "type": "string",
      "const": "cpu"
    },
    "manufacturer": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "socket": {
      "type": "string"
    },
    "microarchitecture": {
      "type": "string"
    },
    "architecture": {
      "type": "string",
      "description": "User-friendly architecture name for display (e.g., Zen 5, 14th Gen Core)"
    },
    "pcie_config": {
      "type": "object",
      "required": ["cpu_gen"],
      "additionalProperties": false,
      "properties": {
        "cpu_gen": {
          "type": "integer",
          "minimum": 1
        },
        "cpu_lanes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cores": {
      "type": "integer",
      "minimum": 1,
      "description": "Total core count"
    },
    "threads": {
      "type": "integer",
      "minimum": 1,
      "description": "Total thread count"
    },
    "tdp_w": {
      "type": "integer",
      "minimum": 1,
      "description": "Thermal design power in watts"
    },
    "schema_version": {
      "type": "string"
    }
  }
}
